# ============================================================
# TaxiPulse — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git
# ============================================================

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=taxipulse
MINIO_SECRET_KEY=taxipulse123
MINIO_BUCKET_NAME=taxipulse-data-lake
MINIO_BRONZE_PREFIX=bronze/
MINIO_SILVER_PREFIX=silver/
MINIO_GOLD_PREFIX=gold/
MINIO_USE_SSL=false

# MinIO Console (Web UI)
MINIO_CONSOLE_PORT=9001

# --- PostgreSQL (Data Warehouse) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taxipulse
POSTGRES_USER=taxipulse
POSTGRES_PASSWORD=taxipulse123
PG_SCHEMA_BRONZE=bronze
PG_SCHEMA_SILVER=silver
PG_SCHEMA_GOLD=gold

# --- NYC TLC Data Source ---
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TLC_DATA_YEAR=2024
TLC_DATA_MONTHS=01,02,03

# --- Apache Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=taxipulse-trips

# --- Slack Alerting ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#taxipulse-alerts

# --- Anomaly Detection ---
ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_CHECK_INTERVAL_HOURS=1

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# --- Streamlit ---
STREAMLIT_PORT=8501